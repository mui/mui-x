{
  "componentDescription": "",
  "propDescriptions": {
    "dataIndex": { "description": "The index to the element in the series&#39; data array." },
    "hidden": { "description": "If <code>true</code>, the marker is hidden." },
    "isFaded": { "description": "If <code>true</code>, the marker is faded." },
    "isHighlighted": { "description": "If <code>true</code>, the marker is highlighted." },
    "shape": { "description": "The shape of the marker." },
    "skipAnimation": { "description": "If <code>true</code>, animations are skipped." }
  },
  "classDescriptions": {
    "animate": {
      "description": "Styles applied to {{nodeName}} when {{conditions}}.",
      "nodeName": "the root element",
      "conditions": "animation is not skipped",
      "deprecationInfo": "Use <code>lineClasses.markAnimate</code> instead."
    },
    "faded": {
      "description": "Styles applied to {{nodeName}} when {{conditions}}.",
      "nodeName": "the root element",
      "conditions": "faded",
      "deprecationInfo": "Use <code>[data-faded]</code> selector instead."
    },
    "highlighted": {
      "description": "Styles applied to {{nodeName}} when {{conditions}}.",
      "nodeName": "the root element",
      "conditions": "highlighted",
      "deprecationInfo": "Use <code>[data-highlighted]</code> selector instead."
    },
    "root": {
      "description": "Styles applied to the root element.",
      "deprecationInfo": "Use <code>lineClasses.mark</code> instead."
    },
    "series": {
      "description": "Styles applied to {{nodeName}}. Needs to be suffixed with the series ID: <code>.${markElementClasses.series}-${seriesId}</code>.",
      "nodeName": "the root element for a specified series",
      "deprecationInfo": "Use <code>[data-series=&quot;${seriesId}&quot;]</code> selector instead."
    }
  }
}
