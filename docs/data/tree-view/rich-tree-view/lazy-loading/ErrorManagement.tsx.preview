<Button
  onClick={() => setFailRequests((prev) => !prev)}
  variant="outlined"
  fullWidth
>
  {failRequests ? 'Resolve requests' : 'Fail Requests'}
</Button>
<div style={{ width: '100%', height: 240 }}>
  <RichTreeViewPro
    items={initialItems}
    dataSource={{
      getChildrenCount: (item) => item?.childrenCount as number,
      getTreeItems: fetchData,
    }}
  />
</div>