<TextField
  select
  label="Tiling method"
  value={method}
  onChange={(event) => setMethod(event.target.value as TreemapTilingMethod)}
  sx={{ maxWidth: 220 }}
>
  {methods.map((value) => (
    <MenuItem key={value} value={value}>
      {value}
    </MenuItem>
  ))}
</TextField>
<Treemap series={{ data, tiling: { method, paddingInner: 2 } }} height={300} />