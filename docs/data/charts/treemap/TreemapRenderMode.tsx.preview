<TextField
  select
  label="Render mode"
  value={renderMode}
  onChange={(event) => setRenderMode(event.target.value as 'all' | 'leaf')}
  sx={{ maxWidth: 220 }}
>
  <MenuItem value="all">all</MenuItem>
  <MenuItem value="leaf">leaf</MenuItem>
</TextField>
<Treemap series={{ data, nodeOptions: { renderMode } }} height={300} />