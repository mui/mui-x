<CandlestickChart
  xAxis={[{ data: xData, zoom: { minSpan: 1, filterMode: 'discard' } }]}
  series={[
    {
      data,
      colorGetter: ({ value }) => {
        if (!value) {
          return 'transparent';
        }
        const [open, , , close] = value;
        return close >= open ? '#7B2FBE' : '#F28C28';
      },
    },
  ]}
  height={400}
/>