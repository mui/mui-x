<CandlestickChart
  series={[{
    data,
    colorGetter: ({ value }) => {
      if (!value) { return 'transparent'; }
      const [open, , , close] = value;
      const t = Math.min(Math.abs(close - open) / open / 0.02, 1);
      const lo = Math.round(200 - 150 * t);
      const hi = Math.round(220 - 40 * t);
      return close >= open ? `rgb(${lo},${hi},${lo})` : `rgb(${hi},${lo},${lo})`;
    },
  }]}
  {...chartConfig}
/>