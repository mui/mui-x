{METHODS.map((method) => (
  <Box key={method.value}>
    <Typography variant="caption" color="text.secondary">
      {method.label}
    </Typography>
    <LineChartPro
      series={[{ data, showMark: false }]}
      xAxis={[{ data: xData, zoom: true }]}
      yAxis={[{ width: 40 }]}
      height={160}
      sampling={method.value}
      hideLegend
    />
  </Box>
))}