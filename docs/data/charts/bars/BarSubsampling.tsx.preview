<FormControlLabel
  control={
    <Switch
      checked={subsampling}
      onChange={(event) => setSubsampling(event.target.checked)}
    />
  }
  label={`Subsampling ${subsampling ? 'on' : 'off'} (${POINTS} bars)`}
/>
<BarChartPro
  xAxis={[{ data: categories, zoom: true, tickSpacing: 100 }]}
  series={[{ data, label: 'Value' }]}
  height={300}
  subsampling={subsampling}
/>