<FormControlLabel
  control={
    <Switch
      checked={sampling}
      onChange={(event) => setSampling(event.target.checked)}
    />
  }
  label={`Sampling ${sampling ? 'on' : 'off'} (${POINTS} bars — zoom in fully to reach the unsampled data)`}
/>
<BarChartPro
  xAxis={[{ scaleType: 'band', data: categories, zoom: true, disableTicks: true, tickLabelInterval: (value, index) => Math.floor(index % 200) === 0 }]}
  series={[{ data, label: 'Value' }]}
  height={300}
  sampling={sampling}
/>