<BarChart
  {...settings}
  sx={{
    [`& .${barClasses.series}[data-series="2"] .${barClasses.label}`]: {
      fill: 'url(#bar-gradient)',
    },
    [`& .${barClasses.seriesLabels}[data-series="2"] .${barClasses.label}`]: {
      fontWeight: 'bold',
    },
  }}
>
  <defs>
    <Gradient id="bar-gradient" />
  </defs>
</BarChart>