  conversations={directoryConversations}
  activeConversationId={activeId}
>
  <Box
    sx={{
      height: 320,
      overflow: 'hidden',
      border: '1px solid',
      borderColor: 'divider',
      borderRadius: 1,
    }}
  >
    <ChatConversationList slots={{ item: FullCustomRow }} />
  </Box>
</ScopedChat>