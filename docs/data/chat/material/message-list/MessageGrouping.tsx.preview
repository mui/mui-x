<ChatBox
  adapter={adapter}
  initialActiveConversationId={conversation.id}
  initialConversations={[conversation]}
  initialMessages={messages}
  slotProps={{
    messageGroup: { groupingWindowMs: 60000 },
  }}
  sx={{
    height: 400,
    border: '1px solid',
    borderColor: 'divider',
    borderRadius: 1,
  }}
/>