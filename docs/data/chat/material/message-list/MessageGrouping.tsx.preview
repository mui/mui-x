<ChatBox
  adapter={adapter}
  initialActiveConversationId={conversation.id}
  initialConversations={[conversation]}
  initialMessages={messages}
  slotProps={{
    group: { groupKey: createTimeWindowGroupKey(60_000) },
  }}
  sx={{
    height: 400,
    border: '1px solid',
    borderColor: 'divider',
    borderRadius: 1,
  }}
/>