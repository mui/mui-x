<Paper
  elevation={0}
  sx={{ border: 1, borderColor: 'divider', overflow: 'hidden' }}
>
  <Box sx={{ height: 480 }}>
    <ChatBox
      adapter={adapter}
      defaultActiveConversationId="design"
      defaultConversations={inboxConversations}
      defaultMessages={inboxThreads.design}
      slotProps={{
        conversations: { dense: true },
      }}
    />
  </Box>
</Paper>