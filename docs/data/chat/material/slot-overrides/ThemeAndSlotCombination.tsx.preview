<ThemeProvider theme={theme}>
  <ChatBox
    adapter={adapter}
    defaultActiveConversationId={minimalConversation.id}
    defaultConversations={[minimalConversation]}
    defaultMessages={minimalMessages}
    slots={{ messageAvatar: BotAvatar }}
    sx={{
      height: 500,
      border: '1px solid',
      borderColor: 'divider',
      borderRadius: 1,
    }}
  />
</ThemeProvider>