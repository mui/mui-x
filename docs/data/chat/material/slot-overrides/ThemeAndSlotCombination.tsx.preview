<ThemeProvider theme={theme}>
  <ChatBox
    adapter={adapter}
    initialActiveConversationId={minimalConversation.id}
    initialConversations={[minimalConversation]}
    initialMessages={minimalMessages}
    slots={{ messageAvatar: BotAvatar }}
    sx={{
      height: 500,
      border: '1px solid',
      borderColor: 'divider',
      borderRadius: 1,
    }}
  />
</ThemeProvider>