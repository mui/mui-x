<Paper
  elevation={0}
  sx={{ border: 1, borderColor: 'divider', overflow: 'hidden' }}
>
  <Box sx={{ height: 480 }}>
    <ChatBox
      adapter={adapter}
      messages={messages}
      onMessagesChange={setMessages}
    />
  </Box>
</Paper>
<Typography color="text.secondary" variant="caption">
  Controlled message count: {messages.length}
</Typography>