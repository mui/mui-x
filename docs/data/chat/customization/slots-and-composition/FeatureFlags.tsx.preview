<ChatBox
  adapter={adapter}
  initialActiveConversationId={minimalConversation.id}
  initialConversations={[minimalConversation]}
  initialMessages={minimalMessages}
  features={{
    conversations: false,
    attachments: false,
  }}
  sx={{
    height: 500,
    border: '1px solid',
    borderColor: 'divider',
    borderRadius: 1,
  }}
/>