  adapter={adapter}
  initialConversations={initialConversations}
  initialActiveConversationId={CONVERSATION_ID}
  initialMessages={initialMessages}
  // ChatBox fills its container — give it an explicit height in your layout.
  sx={{
    height: 500,
    border: '1px solid',
    borderColor: 'divider',
    borderRadius: 1,
  }}
/>