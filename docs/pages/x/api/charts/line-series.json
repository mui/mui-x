{
  "name": "LineSeries",
  "imports": [
    "import { LineSeries } from '@mui/x-charts';",
    "import { LineSeries } from '@mui/x-charts-pro';",
    "import { LineSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "area": { "type": { "description": "boolean" } },
    "baseline": { "type": { "description": "number | \"max\" | \"min\"" }, "default": "0" },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": { "description": "(data: ColorCallbackValue&lt;number | null&gt;) =&gt; string" }
    },
    "connectNulls": { "type": { "description": "boolean" }, "default": "false" },
    "curve": {
      "type": {
        "description": "\"step\" | \"linear\" | \"catmullRom\" | \"monotoneX\" | \"monotoneY\" | \"natural\" | \"stepBefore\" | \"stepAfter\" | \"bumpY\" | \"bumpX\""
      },
      "default": "'monotoneX'"
    },
    "data": { "type": { "description": "readonly (number | null)[]" } },
    "dataKey": { "type": { "description": "string" } },
    "disableHighlight": { "type": { "description": "boolean" }, "default": "false" },
    "highlightScope": { "type": { "description": "CommonHighlightScope" } },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "string | ((location: \"legend\" | \"tooltip\") =&gt; string)" }
    },
    "labelMarkType": {
      "type": {
        "description": "\"circle\" | \"line\" | \"square\" | \"line+mark\" | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "shape": {
      "type": {
        "description": "\"circle\" | \"square\" | \"cross\" | \"diamond\" | \"star\" | \"triangle\" | \"wye\""
      }
    },
    "showMark": {
      "type": {
        "description": "boolean | ((params: ShowMarkParams&lt;number | Date&gt;) =&gt; boolean)"
      }
    },
    "stack": { "type": { "description": "string" } },
    "stackOffset": {
      "type": {
        "description": "\"none\" | \"expand\" | \"diverging\" | \"silhouette\" | \"wiggle\""
      },
      "default": "'none'"
    },
    "stackOrder": {
      "type": {
        "description": "\"appearance\" | \"none\" | \"reverse\" | \"ascending\" | \"descending\" | \"insideOut\""
      },
      "default": "'none'"
    },
    "strictStepCurve": { "type": { "description": "boolean" } },
    "type": { "type": { "description": "\"line\"" } },
    "valueFormatter": { "type": { "description": "SeriesValueFormatter&lt;number | null&gt;" } },
    "xAxisId": { "type": { "description": "string | number" } },
    "yAxisId": { "type": { "description": "string | number" } }
  }
}
