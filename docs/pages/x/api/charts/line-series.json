{
  "name": "LineSeries",
  "imports": [
    "import { LineSeries } from '@mui/x-charts';",
    "import { LineSeries } from '@mui/x-charts-pro';",
    "import { LineSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "area": { "type": { "description": "boolean | undefined" } },
    "baseline": {
      "type": { "description": "number | \"max\" | \"min\" | undefined" },
      "default": "0"
    },
    "color": { "type": { "description": "string | undefined" } },
    "colorGetter": {
      "type": {
        "description": "((data: ColorCallbackValue&lt;number | null&gt;) =&gt; string) | undefined"
      }
    },
    "connectNulls": { "type": { "description": "boolean | undefined" }, "default": "false" },
    "curve": { "type": { "description": "CurveType | undefined" }, "default": "'monotoneX'" },
    "data": { "type": { "description": "readonly (number | null)[] | undefined" } },
    "dataKey": { "type": { "description": "string | undefined" } },
    "disableHighlight": { "type": { "description": "boolean | undefined" }, "default": "false" },
    "highlightScope": { "type": { "description": "CommonHighlightScope | undefined" } },
    "id": { "type": { "description": "string | undefined" } },
    "label": {
      "type": {
        "description": "string | ((location: \"tooltip\" | \"legend\") =&gt; string) | undefined"
      }
    },
    "labelMarkType": { "type": { "description": "ChartsLabelMarkType | undefined" } },
    "shape": { "type": { "description": "MarkShape | undefined" } },
    "showMark": {
      "type": {
        "description": "boolean | ((params: ShowMarkParams&lt;number | Date&gt;) =&gt; boolean) | undefined"
      }
    },
    "stack": { "type": { "description": "string | undefined" } },
    "stackOffset": {
      "type": { "description": "StackOffsetType | undefined" },
      "default": "'none'"
    },
    "stackOrder": { "type": { "description": "StackOrderType | undefined" }, "default": "'none'" },
    "strictStepCurve": { "type": { "description": "boolean | undefined" } },
    "type": { "type": { "description": "\"line\" | undefined" } },
    "valueFormatter": {
      "type": { "description": "SeriesValueFormatter&lt;number | null&gt; | undefined" }
    },
    "xAxisId": { "type": { "description": "AxisId | undefined" } },
    "yAxisId": { "type": { "description": "AxisId | undefined" } }
  }
}
