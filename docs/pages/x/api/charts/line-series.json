{
  "name": "LineSeries",
  "imports": [
    "import { LineSeries } from '@mui/x-charts';",
    "import { LineSeries } from '@mui/x-charts-pro';",
    "import { LineSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "type": { "type": { "description": "'line'" }, "required": true },
    "area": { "type": { "description": "boolean" } },
    "baseline": { "type": { "description": "'max' | 'min' | number" }, "default": "0" },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": { "description": "(data: { value: null | number, dataIndex: number }) =&gt; string" }
    },
    "connectNulls": { "type": { "description": "boolean" }, "default": "false" },
    "curve": {
      "type": {
        "description": "'bumpX' | 'bumpY' | 'catmullRom' | 'linear' | 'monotoneX' | 'monotoneY' | 'natural' | 'step' | 'stepAfter' | 'stepBefore'"
      },
      "default": "'monotoneX'"
    },
    "data": { "type": { "description": "readonly (number | null)[]" } },
    "dataKey": { "type": { "description": "string" } },
    "disableHighlight": { "type": { "description": "boolean" }, "default": "false" },
    "highlightScope": {
      "type": {
        "description": "{ highlight?: 'item' | 'none' | 'series' | undefined, fade?: 'global' | 'none' | 'series' | undefined }"
      }
    },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "(location: 'legend' | 'tooltip') =&gt; string | string" }
    },
    "labelMarkType": {
      "type": {
        "description": "'circle' | 'line' | 'line+mark' | 'square' | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "shape": {
      "type": {
        "description": "'circle' | 'cross' | 'diamond' | 'square' | 'star' | 'triangle' | 'wye'"
      }
    },
    "showMark": {
      "type": {
        "description": "(params: { index: number, x: number, y: number, position: Date | number, value: number }) =&gt; boolean | boolean"
      }
    },
    "stack": { "type": { "description": "string" } },
    "stackOffset": {
      "type": { "description": "'diverging' | 'expand' | 'none' | 'silhouette' | 'wiggle'" },
      "default": "'none'"
    },
    "stackOrder": {
      "type": {
        "description": "'appearance' | 'ascending' | 'descending' | 'insideOut' | 'none' | 'reverse'"
      },
      "default": "'none'"
    },
    "strictStepCurve": { "type": { "description": "boolean" } },
    "valueFormatter": {
      "type": {
        "description": "(value: null | number, context: { dataIndex: number }) =&gt; null | string"
      }
    },
    "valueGetter": {
      "type": { "description": "(item: DatasetElementType&lt;unknown&gt;) =&gt; null | number" }
    },
    "xAxisId": { "type": { "description": "number | string" } },
    "yAxisId": { "type": { "description": "number | string" } }
  }
}
