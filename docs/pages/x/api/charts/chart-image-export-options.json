{
  "name": "ChartImageExportOptions",
  "imports": ["import { ChartImageExportOptions } from '@mui/x-charts-pro';"],
  "demos": "  - [Image export](https://mui.com/x/react-charts/export/#export-as-image)",
  "properties": {
    "copyStyles": {
      "type": { "description": "boolean | undefined" },
      "default": "true",
      "isProPlan": true
    },
    "fileName": {
      "type": { "description": "string | undefined" },
      "default": "The title of the document the chart belongs to",
      "isProPlan": true
    },
    "nonce": { "type": { "description": "string | undefined" }, "isProPlan": true },
    "onBeforeExport": {
      "type": {
        "description": "((iframe: HTMLIFrameElement) =&gt; void | Promise&lt;void&gt;) | undefined"
      },
      "isProPlan": true
    },
    "quality": {
      "type": { "description": "number | undefined" },
      "default": "0.9",
      "isProPlan": true
    },
    "type": {
      "type": { "description": "string | undefined" },
      "default": "'image/png'",
      "isProPlan": true
    }
  }
}
