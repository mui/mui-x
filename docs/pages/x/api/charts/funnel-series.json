{
  "name": "FunnelSeries",
  "imports": [
    "import { FunnelSeries } from '@mui/x-charts-pro';",
    "import { FunnelSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": {
      "type": { "description": "readonly FunnelValueType[]" },
      "required": true,
      "isProPlan": true
    },
    "borderRadius": {
      "type": { "description": "number | undefined" },
      "default": "8",
      "isProPlan": true
    },
    "curve": {
      "type": { "description": "FunnelCurveType | undefined" },
      "default": "'linear'",
      "isProPlan": true
    },
    "funnelDirection": {
      "type": { "description": "\"auto\" | \"increasing\" | \"decreasing\" | undefined" },
      "default": "'auto'",
      "isProPlan": true
    },
    "highlightScope": { "type": { "description": "CommonHighlightScope | undefined" } },
    "id": { "type": { "description": "string | undefined" } },
    "label": {
      "type": {
        "description": "string | ((location: \"legend\" | \"tooltip\") =&gt; string) | undefined"
      },
      "isProPlan": true
    },
    "labelMarkType": { "type": { "description": "ChartsLabelMarkType | undefined" } },
    "layout": {
      "type": { "description": "\"horizontal\" | \"vertical\" | undefined" },
      "default": "'vertical'",
      "isProPlan": true
    },
    "sectionLabel": {
      "type": {
        "description": "false | FunnelLabelOptions | ((item: FunnelItem) =&gt; false | FunnelLabelOptions) | undefined"
      },
      "default": "{ vertical: 'middle', horizontal: 'center' }",
      "isProPlan": true
    },
    "type": { "type": { "description": "\"funnel\" | undefined" }, "isProPlan": true },
    "valueFormatter": {
      "type": { "description": "SeriesValueFormatter&lt;FunnelValueType&gt; | undefined" }
    },
    "variant": {
      "type": { "description": "\"filled\" | \"outlined\" | undefined" },
      "default": "'filled'",
      "isProPlan": true
    },
    "xAxisId": { "type": { "description": "AxisId | undefined" } },
    "yAxisId": { "type": { "description": "AxisId | undefined" } }
  }
}
