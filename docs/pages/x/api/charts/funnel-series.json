{
  "name": "FunnelSeries",
  "imports": [
    "import { FunnelSeries } from '@mui/x-charts-pro';",
    "import { FunnelSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": {
      "type": { "description": "readonly FunnelValueType[]" },
      "required": true,
      "isProPlan": true
    },
    "type": { "type": { "description": "'funnel'" }, "required": true, "isProPlan": true },
    "borderRadius": { "type": { "description": "number" }, "default": "8", "isProPlan": true },
    "curve": {
      "type": {
        "description": "'bump' | 'linear' | 'linear-sharp' | 'pyramid' | 'step' | 'step-pyramid'"
      },
      "default": "'linear'",
      "isProPlan": true
    },
    "funnelDirection": {
      "type": { "description": "'auto' | 'decreasing' | 'increasing'" },
      "default": "'auto'",
      "isProPlan": true
    },
    "highlightScope": {
      "type": {
        "description": "{ highlight?: 'item' | 'none' | 'series' | undefined, fade?: 'global' | 'none' | 'series' | undefined }"
      }
    },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "(location: 'legend' | 'tooltip') =&gt; string | string" },
      "isProPlan": true
    },
    "labelMarkType": {
      "type": {
        "description": "'circle' | 'line' | 'line+mark' | 'square' | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "layout": {
      "type": { "description": "'horizontal' | 'vertical'" },
      "default": "'vertical'",
      "isProPlan": true
    },
    "sectionLabel": {
      "type": {
        "description": "FunnelLabelOptions | ((item: FunnelItem) =&gt; FunnelLabelOptions | false) | false"
      },
      "default": "{ vertical: 'middle', horizontal: 'center' }",
      "isProPlan": true
    },
    "valueFormatter": {
      "type": {
        "description": "(value: { id?: number | string | undefined, value: number, label?: (location: 'legend' | 'section' | 'tooltip') =&gt; string | undefined | string | undefined, color?: string | undefined, labelMarkType?: 'circle' | 'line' | 'line+mark' | 'square' | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt; | undefined }, context: { dataIndex: number }) =&gt; null | string"
      }
    },
    "variant": {
      "type": { "description": "'filled' | 'outlined'" },
      "default": "'filled'",
      "isProPlan": true
    },
    "xAxisId": { "type": { "description": "number | string" } },
    "yAxisId": { "type": { "description": "number | string" } }
  }
}
