{
  "name": "FunnelSeries",
  "imports": [
    "import { FunnelSeries } from '@mui/x-charts-pro';",
    "import { FunnelSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": {
      "type": { "description": "readonly FunnelValueType[]" },
      "required": true,
      "isProPlan": true
    },
    "borderRadius": { "type": { "description": "number" }, "default": "8", "isProPlan": true },
    "curve": {
      "type": {
        "description": "\"step\" | \"linear\" | \"linear-sharp\" | \"bump\" | \"pyramid\" | \"step-pyramid\""
      },
      "default": "'linear'",
      "isProPlan": true
    },
    "funnelDirection": {
      "type": { "description": "\"auto\" | \"increasing\" | \"decreasing\"" },
      "default": "'auto'",
      "isProPlan": true
    },
    "highlightScope": { "type": { "description": "CommonHighlightScope" } },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "string | ((location: \"legend\" | \"tooltip\") =&gt; string)" },
      "isProPlan": true
    },
    "labelMarkType": {
      "type": {
        "description": "\"circle\" | \"line\" | \"square\" | \"line+mark\" | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "layout": {
      "type": { "description": "\"horizontal\" | \"vertical\"" },
      "default": "'vertical'",
      "isProPlan": true
    },
    "sectionLabel": {
      "type": {
        "description": "false | FunnelLabelOptions | ((item: FunnelItem) =&gt; false | FunnelLabelOptions)"
      },
      "default": "{ vertical: 'middle', horizontal: 'center' }",
      "isProPlan": true
    },
    "type": { "type": { "description": "\"funnel\"" }, "isProPlan": true },
    "valueFormatter": { "type": { "description": "SeriesValueFormatter&lt;FunnelValueType&gt;" } },
    "variant": {
      "type": { "description": "\"filled\" | \"outlined\"" },
      "default": "'filled'",
      "isProPlan": true
    },
    "xAxisId": { "type": { "description": "string | number" } },
    "yAxisId": { "type": { "description": "string | number" } }
  }
}
