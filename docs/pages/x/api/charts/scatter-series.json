{
  "name": "ScatterSeries",
  "imports": [
    "import { ScatterSeries } from '@mui/x-charts';",
    "import { ScatterSeries } from '@mui/x-charts-pro';",
    "import { ScatterSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "type": { "type": { "description": "\"scatter\"" }, "required": true },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": {
        "description": "(data: { value: { x: number, y: number, z?: any, id?: string | number }, dataIndex: number }) =&gt; string"
      }
    },
    "data": { "type": { "description": "readonly ScatterValueType[]" } },
    "datasetKeys": {
      "type": { "description": "{ x: string, y: string, z?: string, id?: string }" }
    },
    "highlightScope": {
      "type": {
        "description": "{ highlight?: \"item\" | \"none\" | \"series\", fade?: \"none\" | \"series\" | \"global\" }"
      }
    },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "string | (location: \"legend\" | \"tooltip\") =&gt; string" }
    },
    "labelMarkType": {
      "type": {
        "description": "\"circle\" | \"line\" | \"square\" | \"line+mark\" | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "markerSize": { "type": { "description": "number" } },
    "preview": { "type": { "description": "{ markerSize?: number }" } },
    "valueFormatter": {
      "type": {
        "description": "(value: { x: number, y: number, z?: any, id?: string | number }, context: { dataIndex: number }) =&gt; string"
      }
    },
    "xAxisId": { "type": { "description": "string | number" } },
    "yAxisId": { "type": { "description": "string | number" } },
    "zAxisId": { "type": { "description": "string" } }
  }
}
