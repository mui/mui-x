{
  "name": "ScatterSeries",
  "imports": [
    "import { ScatterSeries } from '@mui/x-charts';",
    "import { ScatterSeries } from '@mui/x-charts-pro';",
    "import { ScatterSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": {
        "description": "(data: ColorCallbackValue&lt;ScatterValueType | null&gt;) =&gt; string"
      }
    },
    "data": { "type": { "description": "readonly ScatterValueType[]" } },
    "datasetKeys": {
      "type": {
        "description": "{\n    /**\n     * The key used to retrieve data from the dataset for the X axis.\n     */\n    x: string;\n    /**\n     * The key used to retrieve data from the dataset for the Y axis.\n     */\n    y: string;\n    /**\n     * The key used to retrieve data from the dataset for the Z axis.\n     */\n    z?: string;\n    /**\n     * The key used to retrieve data from the dataset for the id.\n     */\n    id?: string;\n  }"
      }
    },
    "highlightScope": { "type": { "description": "CommonHighlightScope" } },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "string | ((location: \"legend\" | \"tooltip\") =&gt; string)" }
    },
    "labelMarkType": { "type": { "description": "ChartsLabelMarkType" } },
    "markerSize": { "type": { "description": "number" } },
    "preview": { "type": { "description": "{ markerSize?: number | undefined; }" } },
    "type": { "type": { "description": "\"scatter\"" } },
    "valueFormatter": {
      "type": { "description": "SeriesValueFormatter&lt;ScatterValueType | null&gt;" }
    },
    "xAxisId": { "type": { "description": "AxisId" } },
    "yAxisId": { "type": { "description": "AxisId" } },
    "zAxisId": { "type": { "description": "string" } }
  }
