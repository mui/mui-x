{
  "name": "ScatterSeries",
  "imports": [
    "import { ScatterSeries } from '@mui/x-charts-premium';",
    "import { ScatterSeries } from '@mui/x-charts-pro';",
    "import { ScatterSeries } from '@mui/x-charts';"
  ],
  "properties": {
    "type": { "type": { "description": "'scatter'" }, "required": true },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": {
        "description": "(data: { value: { x: number, y: number, z?: any, id?: number | string }, dataIndex: number }) =&gt; string"
      }
    },
    "data": { "type": { "description": "readonly ScatterValueType[]" } },
    "datasetKeys": {
      "type": { "description": "{ x: string, y: string, z?: string, id?: string }" }
    },
    "highlightScope": {
      "type": {
        "description": "{ highlight?: 'item' | 'none' | 'series', fade?: 'global' | 'none' | 'series' }"
      }
    },
    "id": { "type": { "description": "string" } },
    "label": {
      "type": { "description": "(location: 'legend' | 'tooltip') =&gt; string | string" }
    },
    "labelMarkType": {
      "type": {
        "description": "'circle' | 'line' | 'line+mark' | 'square' | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "markerSize": { "type": { "description": "number" } },
    "preview": { "type": { "description": "{ markerSize?: number }" } },
    "valueFormatter": {
      "type": {
        "description": "(value: { x: number, y: number, z?: any, id?: number | string }, context: { dataIndex: number }) =&gt; string"
      }
    },
    "valueGetter": {
      "type": {
        "description": "(item: DatasetElementType&lt;unknown&gt;) =&gt; { x: number, y: number, z?: any, id?: number | string }"
      }
    },
    "xAxisId": { "type": { "description": "number | string" } },
    "yAxisId": { "type": { "description": "number | string" } },
    "zAxisId": { "type": { "description": "string" } }
  }
}
