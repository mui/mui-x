{
  "name": "ChartPrintExportOptions",
  "imports": ["import { ChartPrintExportOptions } from '@mui/x-charts-pro';"],
  "demos": "  - [Print export](https://mui.com/x/react-charts/export/#print-export-as-pdf)",
  "properties": {
    "copyStyles": {
      "type": { "description": "boolean | undefined" },
