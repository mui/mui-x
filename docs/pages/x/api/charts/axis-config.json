{
  "name": "AxisConfig",
  "imports": [
    "import { AxisConfig } from '@mui/x-charts';",
    "import { AxisConfig } from '@mui/x-charts-pro';",
    "import { AxisConfig } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "id": { "type": { "description": "AxisId" }, "required": true },
    "classes": { "type": { "description": "Partial&lt;AxisProps&gt;[\"classes\"] | undefined" } },
    "className": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"className\"] | undefined" }
    },
    "colorMap": {
      "type": {
        "description": "Omit&lt;AxisScaleConfig[S], \"scale\"&gt;[\"colorMap\"] | undefined"
      }
    },
    "data": { "type": { "description": "readonly V[] | undefined" } },
    "dataKey": { "type": { "description": "string | undefined" } },
    "disableLine": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"disableLine\"] | undefined" },
      "default": "false"
    },
    "disableTicks": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"disableTicks\"] | undefined" },
      "default": "false"
    },
    "domainLimit": {
      "type": {
        "description": "\"nice\" | \"strict\" | ((min: NumberValue, max: NumberValue) =&gt; { min: NumberValue; max: NumberValue; }) | undefined"
      }
    },
    "height": {
      "type": { "description": "number | \"auto\" | undefined" },
      "default": "45 if an axis label is provided, 25 otherwise."
    },
    "hideTooltip": { "type": { "description": "boolean | undefined" } },
    "ignoreTooltip": { "type": { "description": "boolean | undefined" } },
    "label": { "type": { "description": "Partial&lt;AxisProps&gt;[\"label\"] | undefined" } },
    "labelStyle": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"labelStyle\"] | undefined" }
    },
    "offset": { "type": { "description": "number | undefined" }, "default": "0" },
    "position": { "type": { "description": "\"bottom\" | \"top\" | \"none\" | undefined" } },
    "reverse": { "type": { "description": "boolean | undefined" } },
    "scaleType": {
      "type": {
        "description": "Omit&lt;AxisScaleConfig[S], \"scale\"&gt;[\"scaleType\"] | undefined"
      }
    },
    "slotProps": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"slotProps\"] | undefined" },
      "default": "{}"
    },
    "slots": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"slots\"] | undefined" },
      "default": "{}"
    },
    "sx": { "type": { "description": "Partial&lt;AxisProps&gt;[\"sx\"] | undefined" } },
    "tickInterval": {
      "type": {
        "description": "(Partial&lt;AxisProps&gt;[\"tickInterval\"] & (any[] | \"auto\" | ((value: any, index: number) =&gt; boolean))) | undefined"
      },
      "default": "'auto'"
    },
    "tickLabelInterval": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"tickLabelInterval\"] | undefined" },
      "default": "'auto'"
    },
    "tickLabelPlacement": {
      "type": {
        "description": "(Partial&lt;AxisProps&gt;[\"tickLabelPlacement\"] & (\"middle\" | \"tick\")) | undefined"
      },
      "default": "'middle'"
    },
    "tickLabelStyle": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"tickLabelStyle\"] | undefined" }
    },
    "tickMaxStep": {
      "type": { "description": "(Partial&lt;AxisProps&gt;[\"tickMaxStep\"] & number) | undefined" }
    },
    "tickMinStep": {
      "type": { "description": "(Partial&lt;AxisProps&gt;[\"tickMinStep\"] & number) | undefined" }
    },
    "tickNumber": {
      "type": { "description": "(Partial&lt;AxisProps&gt;[\"tickNumber\"] & number) | undefined" }
    },
    "tickPlacement": {
      "type": {
        "description": "(Partial&lt;AxisProps&gt;[\"tickPlacement\"] & (\"start\" | \"end\" | \"middle\" | \"extremities\")) | undefined"
      },
      "default": "'extremities'"
    },
    "tickSize": {
      "type": { "description": "Partial&lt;AxisProps&gt;[\"tickSize\"] | undefined" },
      "default": "6"
    },
    "tickSpacing": {
      "type": { "description": "(Partial&lt;AxisProps&gt;[\"tickSpacing\"] & number) | undefined" },
      "default": "0"
    },
    "valueFormatter": {
      "type": {
        "description": "(&lt;TScaleName extends S&gt;(value: V, context: AxisValueFormatterContext&lt;TScaleName&gt;) =&gt; string) | undefined"
      }
    },
    "zoom": { "type": { "description": "boolean | ZoomOptions | undefined" }, "isProPlan": true }
  }
}
