{
  "name": "PieSeries",
  "imports": [
    "import { PieSeries } from '@mui/x-charts';",
    "import { PieSeries } from '@mui/x-charts-pro';",
    "import { PieSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": {
      "type": { "description": "readonly MakeOptional&lt;PieValueType, \"id\"&gt;[]" },
      "required": true
    },
    "type": { "type": { "description": "\"pie\"" }, "required": true },
    "arcLabel": {
      "type": {
        "description": "| 'formattedValue'\n    | 'label'\n    | 'value'\n    | ((item: Omit&lt;DefaultizedPieValueType, 'label'&gt; & { label?: string }) =&gt; string)"
      }
    },
    "arcLabelMinAngle": { "type": { "description": "number" }, "default": "0" },
    "arcLabelRadius": {
      "type": { "description": "string | number" },
      "default": "(innerRadius - outerRadius) / 2"
    },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": {
        "description": "(data: { value: MakeOptional&lt;PieValueType, \"id\"&gt;, dataIndex: number }) =&gt; string"
      }
    },
    "cornerRadius": { "type": { "description": "number" }, "default": "0" },
    "cx": { "type": { "description": "string | number" }, "default": "'50%'" },
    "cy": { "type": { "description": "string | number" }, "default": "'50%'" },
    "endAngle": { "type": { "description": "number" }, "default": "360" },
    "faded": {
      "type": {
        "description": "{ additionalRadius?: number, innerRadius?: number, outerRadius?: number, cornerRadius?: number, paddingAngle?: number, arcLabelRadius?: number, color?: string }"
      }
    },
    "highlighted": {
      "type": {
        "description": "{ additionalRadius?: number, innerRadius?: number, outerRadius?: number, cornerRadius?: number, paddingAngle?: number, arcLabelRadius?: number, color?: string }"
      }
    },
    "highlightScope": {
      "type": {
        "description": "{ highlight?: \"item\" | \"none\" | \"series\", fade?: \"none\" | \"series\" | \"global\" }"
      }
    },
    "id": { "type": { "description": "string" } },
    "innerRadius": { "type": { "description": "string | number" }, "default": "0" },
    "labelMarkType": {
      "type": {
        "description": "\"circle\" | \"line\" | \"square\" | \"line+mark\" | ComponentClass&lt;ChartsLabelCustomMarkProps, any&gt; | FunctionComponent&lt;ChartsLabelCustomMarkProps&gt;"
      }
    },
    "outerRadius": { "type": { "description": "string | number" }, "default": "'100%'" },
    "paddingAngle": { "type": { "description": "number" }, "default": "0" },
    "sortingValues": {
      "type": {
        "description": "\"asc\" | \"desc\" | \"none\" | (a: number, b: number) =&gt; number"
      },
      "default": "'none'"
    },
    "startAngle": { "type": { "description": "number" }, "default": "0" },
    "valueFormatter": {
      "type": {
        "description": "(value: MakeOptional&lt;PieValueType, \"id\"&gt;, context: { dataIndex: number }) =&gt; string"
      }
    }
  }
}
