{
  "name": "PieSeries",
  "imports": [
    "import { PieSeries } from '@mui/x-charts';",
    "import { PieSeries } from '@mui/x-charts-pro';",
    "import { PieSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": {
      "type": { "description": "readonly MakeOptional&lt;PieValueType, \"id\"&gt;[]" },
      "required": true
    },
    "arcLabel": {
      "type": {
        "description": "\"label\" | \"value\" | \"formattedValue\" | ((item: Omit&lt;DefaultizedPieValueType, \"label\"&gt; & { label?: string | undefined; }) =&gt; string) | undefined"
      }
    },
    "arcLabelMinAngle": { "type": { "description": "number | undefined" }, "default": "0" },
    "arcLabelRadius": {
      "type": { "description": "string | number | undefined" },
      "default": "(innerRadius - outerRadius) / 2"
    },
    "color": { "type": { "description": "string | undefined" } },
    "colorGetter": {
      "type": {
        "description": "((data: ColorCallbackValue&lt;MakeOptional&lt;PieValueType, \"id\"&gt;&gt;) =&gt; string) | undefined"
      }
    },
    "cornerRadius": { "type": { "description": "number | undefined" }, "default": "0" },
    "cx": { "type": { "description": "string | number | undefined" }, "default": "'50%'" },
    "cy": { "type": { "description": "string | number | undefined" }, "default": "'50%'" },
    "endAngle": { "type": { "description": "number | undefined" }, "default": "360" },
    "faded": {
      "type": {
        "description": "{ additionalRadius?: number | undefined; innerRadius?: number | undefined; outerRadius?: number | undefined; cornerRadius?: number | undefined; paddingAngle?: number | undefined; arcLabelRadius?: number | undefined; color?: string | undefined; } | undefined"
      }
    },
    "highlighted": {
      "type": {
        "description": "{ additionalRadius?: number | undefined; innerRadius?: number | undefined; outerRadius?: number | undefined; cornerRadius?: number | undefined; paddingAngle?: number | undefined; arcLabelRadius?: number | undefined; color?: string | undefined; } | undefined"
      }
    },
    "highlightScope": { "type": { "description": "CommonHighlightScope | undefined" } },
    "id": { "type": { "description": "string | undefined" } },
    "innerRadius": { "type": { "description": "string | number | undefined" }, "default": "0" },
    "labelMarkType": { "type": { "description": "ChartsLabelMarkType | undefined" } },
    "outerRadius": {
      "type": { "description": "string | number | undefined" },
      "default": "'100%'"
    },
    "paddingAngle": { "type": { "description": "number | undefined" }, "default": "0" },
    "sortingValues": {
      "type": { "description": "ChartsPieSorting | undefined" },
      "default": "'none'"
    },
    "startAngle": { "type": { "description": "number | undefined" }, "default": "0" },
    "type": { "type": { "description": "\"pie\" | undefined" } },
    "valueFormatter": {
      "type": {
        "description": "SeriesValueFormatter&lt;MakeOptional&lt;PieValueType, \"id\"&gt;&gt; | undefined"
      }
    }
  }
}
