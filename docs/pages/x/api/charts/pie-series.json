{
  "name": "PieSeries",
  "imports": [
    "import { PieSeries } from '@mui/x-charts';",
    "import { PieSeries } from '@mui/x-charts-pro';",
    "import { PieSeries } from '@mui/x-charts-premium';"
  ],
  "properties": {
    "data": { "type": { "description": "Readonly&lt;TData[]&gt;" }, "required": true },
    "arcLabel": {
      "type": {
        "description": " | 'formattedValue' | 'label' | 'value' | ((item: Omit&lt;DefaultizedPieValueType, 'label'&gt; & { label?: string }) =&gt; string)"
      }
    },
    "arcLabelMinAngle": { "type": { "description": "number" }, "default": "0" },
    "arcLabelRadius": {
      "type": { "description": "string | number" },
      "default": "(innerRadius - outerRadius) / 2"
    },
    "color": { "type": { "description": "string" } },
    "colorGetter": {
      "type": { "description": "(data: ColorCallbackValue&lt;TValue&gt;) =&gt; string" }
    },
    "cornerRadius": { "type": { "description": "number" }, "default": "0" },
    "cx": { "type": { "description": "string | number" }, "default": "'50%'" },
    "cy": { "type": { "description": "string | number" }, "default": "'50%'" },
    "endAngle": { "type": { "description": "number" }, "default": "360" },
    "faded": {
      "type": {
        "description": "{\n    /**\n     * Value added to the default `outerRadius`.\n     * Can be negative. It is ignored if you provide a `faded.outerRadius` value.\n     */\n    additionalRadius?: number;\n    innerRadius?: number;\n    outerRadius?: number;\n    cornerRadius?: number;\n    paddingAngle?: number;\n    arcLabelRadius?: number;\n    color?: string;\n  }"
      }
    },
    "highlighted": {
      "type": {
        "description": "{\n    /**\n     * Value added to the default `outerRadius`.\n     * Can be negative. It is ignored if you provide a `highlighted.outerRadius` value.\n     */\n    additionalRadius?: number;\n    innerRadius?: number;\n    outerRadius?: number;\n    cornerRadius?: number;\n    paddingAngle?: number;\n    arcLabelRadius?: number;\n    color?: string;\n  }"
      }
    },
    "highlightScope": { "type": { "description": "CommonHighlightScope" } },
    "id": { "type": { "description": "string" } },
    "innerRadius": { "type": { "description": "string | number" }, "default": "0" },
    "labelMarkType": { "type": { "description": "ChartsLabelMarkType" } },
    "outerRadius": { "type": { "description": "string | number" }, "default": "'100%'" },
    "paddingAngle": { "type": { "description": "number" }, "default": "0" },
    "sortingValues": { "type": { "description": "ChartsPieSorting" }, "default": "'none'" },
    "startAngle": { "type": { "description": "number" }, "default": "0" },
    "type": { "type": { "description": "\"pie\"" } },
    "valueFormatter": { "type": { "description": "SeriesValueFormatter&lt;TValue&gt;" } }
  }
}
