{
  "name": "GridRowSelectionApi",
  "description": "The selection API interface that is available in the grid [[apiRef]].",
  "properties": {
    "selectRow": {
      "type": {
        "description": "(id: string | number, isSelected?: boolean, resetSelection?: boolean) =&gt; void"
      }
    },
    "isRowSelected": { "type": { "description": "(id: string | number) =&gt; boolean" } },
    "isRowSelectable": { "type": { "description": "(id: string | number) =&gt; boolean" } },
    "getSelectedRows": {
      "type": { "description": "() =&gt; Map&lt;GridRowId, GridValidRowModel&gt;" }
    },
    "setRowSelectionModel": {
      "type": {
        "description": "(rowSelectionModel: { type: \"include\" | \"exclude\", ids: Set&lt;GridRowId&gt; }, reason?: \"singleRowSelection\" | \"multipleRowsSelection\") =&gt; void"
      }
    }
  }
}
