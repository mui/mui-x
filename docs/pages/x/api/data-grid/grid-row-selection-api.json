{
  "name": "GridRowSelectionApi",
  "description": "The selection API interface that is available in the grid [[apiRef]].",
  "properties": {
    "selectRow": {
      "type": {
        "description": "(id: GridRowId, isSelected?: boolean | undefined, resetSelection?: boolean | undefined) =&gt; void"
      }
    },
    "isRowSelected": { "type": { "description": "(id: GridRowId) =&gt; boolean" } },
    "isRowSelectable": { "type": { "description": "(id: GridRowId) =&gt; boolean" } },
    "getSelectedRows": {
      "type": { "description": "() =&gt; Map&lt;GridRowId, GridValidRowModel&gt;" }
    },
    "setRowSelectionModel": {
      "type": {
        "description": "(rowSelectionModel: GridRowSelectionModel, reason?: \"singleRowSelection\" | \"multipleRowsSelection\" | undefined) =&gt; void"
      }
    }
  }
}
