{
  "name": "GridCsvExportOptions",
  "imports": [
    "import { GridCsvExportOptions } from '@mui/x-data-grid';",
    "import { GridCsvExportOptions } from '@mui/x-data-grid-pro';",
    "import { GridCsvExportOptions } from '@mui/x-data-grid-premium';"
  ],
  "demos": "  - [CSV export](/x/react-data-grid/export/#csv-export)",
  "properties": {
    "allColumns": { "type": { "description": "boolean | undefined" }, "default": "false" },
    "delimiter": { "type": { "description": "string | undefined" }, "default": "','" },
    "escapeFormulas": { "type": { "description": "boolean | undefined" }, "default": "true" },
    "fields": { "type": { "description": "string[] | undefined" } },
    "fileName": { "type": { "description": "string | undefined" }, "default": "document.title" },
    "getRowsToExport": {
      "type": {
