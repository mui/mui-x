{
  "name": "GridSortApi",
  "description": "The sort API interface that is available in the grid [[apiRef]].",
  "properties": {
    "getSortModel": { "type": { "description": "() =&gt; GridSortModel" } },
    "applySorting": { "type": { "description": "() =&gt; void" } },
    "setSortModel": { "type": { "description": "(model: GridSortModel) =&gt; void" } },
    "sortColumn": {
      "type": {
        "description": "(field: string, direction?: \"asc\" | \"desc\", allowMultipleSorting?: boolean) =&gt; void"
      }
    },
    "getSortedRows": { "type": { "description": "() =&gt; GridValidRowModel[]" } },
    "getSortedRowIds": { "type": { "description": "() =&gt; GridRowId[]" } },
    "getRowIdFromRowIndex": { "type": { "description": "(index: number) =&gt; string | number" } }
  }
}
