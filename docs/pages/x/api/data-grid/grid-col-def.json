    },
    "pinnable": { "type": { "description": "boolean" }, "default": "true" },
    "pivotable": { "type": { "description": "boolean" }, "default": "true", "isPremiumPlan": true },
    "preProcessEditCellProps": {
      "type": {
        "description": "((params: GridPreProcessEditCellProps&lt;any, any&gt;) =&gt; GridEditCellProps&lt;any&gt; | Promise&lt;GridEditCellProps&lt;any&gt;&gt;) | ((params: GridPreProcessEditCellProps&lt;any, any&gt;) =&gt; GridEditCellProps&lt;any&gt; | Promise&lt;GridEditCellProps&lt;any&gt;&gt;) | ((params: GridPreProcessEditCellProps&lt;any, any&gt;) =&gt; GridEditCellProps&lt;any&gt; | Promise&lt;GridEditCellProps&lt;any&gt;&gt;)"
      }
    },
    "renderCell": {
      "type": {
        "description": "((params: GridRenderCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode) | ((params: GridRenderCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode) | ((params: GridRenderCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode)"
      }
    },
    "renderEditCell": {
      "type": {
        "description": "((params: GridRenderEditCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode) | ((params: GridRenderEditCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode) | ((params: GridRenderEditCellParams&lt;R, V, F, GridTreeNodeWithRender&gt;) =&gt; ReactNode)"
      }
    },
    "renderHeader": {
      "type": {
        "description": "((params: GridColumnHeaderParams&lt;R, V, F&gt;) =&gt; ReactNode) | ((params: GridColumnHeaderParams&lt;R, V, F&gt;) =&gt; ReactNode) | ((params: GridColumnHeaderParams&lt;R, V, F&gt;) =&gt; ReactNode)"
      }
    },
    "renderHeaderFilter": {
      "type": { "description": "(params: GridRenderHeaderFilterProps) =&gt; ReactNode" },
      "isProPlan": true
    },
    "resizable": { "type": { "description": "boolean" }, "default": "true" },
    "rowSpanValueGetter": { "type": { "description": "GridValueGetter&lt;R, V, F, never&gt;" } },
    "sortable": { "type": { "description": "boolean" }, "default": "true" },
    "sortComparator": { "type": { "description": "GridComparatorFn&lt;V&gt;" } },
    "sortingOrder": { "type": { "description": "readonly GridSortDirection[]" } },
    "type": {
      "type": {
        "description": "\"string\" | \"number\" | \"boolean\" | \"date\" | \"dateTime\" | \"singleSelect\" | \"actions\" | \"custom\" | \"longText\""
      },
      "default": "'singleSelect'"
    },
    "valueFormatter": { "type": { "description": "GridValueFormatter&lt;R, V, F, never&gt;" } },
    "valueGetter": { "type": { "description": "GridValueGetter&lt;R, V, F, never&gt;" } },
    "valueParser": { "type": { "description": "GridValueParser&lt;R, V, F&gt;" } },
    "valueSetter": { "type": { "description": "GridValueSetter&lt;R, V, F&gt;" } },
    "width": { "type": { "description": "number" }, "default": "100" }
  }
}
