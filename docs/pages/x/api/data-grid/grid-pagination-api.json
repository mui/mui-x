{
  "name": "GridPaginationApi",
  "description": "The pagination API interface that is available in the grid `apiRef`.",
  "properties": {
    "setPage": { "type": { "description": "(page: number) =&gt; void" } },
    "setPageSize": { "type": { "description": "(pageSize: number) =&gt; void" } },
    "setPaginationModel": {
      "type": { "description": "(model: { pageSize: number, page: number }) =&gt; void" }
    },
    "setRowCount": { "type": { "description": "(rowCount: number) =&gt; void" } },
    "setPaginationMeta": {
      "type": { "description": "(paginationMeta: { hasNextPage?: boolean }) =&gt; void" }
    }
  }
}
