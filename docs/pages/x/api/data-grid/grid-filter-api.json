{
  "name": "GridFilterApi",
  "description": "The filter API interface that is available in the grid [[apiRef]].",
  "properties": {
    "showFilterPanel": {
      "type": {
        "description": "(targetColumnField?: string, panelId?: string, labelId?: string) =&gt; void"
      }
    },
    "hideFilterPanel": { "type": { "description": "() =&gt; void" } },
    "upsertFilterItem": { "type": { "description": "(item: GridFilterItem) =&gt; void" } },
    "upsertFilterItems": { "type": { "description": "(items: GridFilterItem[]) =&gt; void" } },
    "deleteFilterItem": { "type": { "description": "(item: GridFilterItem) =&gt; void" } },
    "setFilterLogicOperator": {
      "type": { "description": "(operator: GridLogicOperator) =&gt; void" }
    },
    "setFilterModel": {
      "type": {
        "description": "(model: GridFilterModel, reason?: \"upsertFilterItem\" | \"upsertFilterItems\" | \"deleteFilterItem\" | \"changeLogicOperator\" | \"restoreState\" | \"removeAllFilterItems\" | undefined) =&gt; void"
      }
    },
    "setQuickFilterValues": { "type": { "description": "(values: any[]) =&gt; void" } },
    "ignoreDiacritics": { "type": { "description": "boolean" } },
    "getFilterState": {
      "type": { "description": "(filterModel: GridFilterModel) =&gt; GridFilterState" }
    }
  }
}
