{
  "name": "@mui/x-license",
  "version": "9.0.0-alpha.0",
  "author": "MUI Team",
  "description": "MUI X License verification.",
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/mui/mui-x/issues"
  },
  "homepage": "https://mui.com/x/introduction/licensing/",
  "sideEffects": [
    "./utils/licenseInfo.js",
    "./esm/utils/licenseInfo.js"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "build"
  },
  "scripts": {
    "typescript": "tsc -p tsconfig.json",
    "build": "code-infra build && pnpm build:update-pkg-json",
    "build:update-pkg-json": "node ./scripts/addPackageScripts.js",
    "prebuild": "rimraf build tsconfig.build.tsbuildinfo"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mui/mui-x.git",
    "directory": "packages/x-license"
  },
  "packageScripts": {
    "postinstall": "node ./esm/telemetry/postinstall/index.js"
  },
  "dependencies": {
    "@babel/runtime": "catalog:",
    "@fingerprintjs/fingerprintjs": "^3.4.2",
    "@mui/utils": "catalog:",
    "@mui/x-internals": "workspace:*",
    "ci-info": "^4.3.1",
    "is-docker": "^4.0.0",
    "node-machine-id": "^1.1.12"
  },
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@mui/internal-test-utils": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "exports": {
    ".": "./src/index.ts",
    "./Watermark": "./src/Watermark/index.ts",
    "./useLicenseVerifier": "./src/useLicenseVerifier/index.ts",
    "./verifyLicense": "./src/verifyLicense/index.ts",
    "./utils": "./src/utils/index.ts",
    "./test-keys": "./src/test-keys.ts"
  }
}
