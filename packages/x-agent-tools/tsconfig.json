{
  "compilerOptions": {
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "target": "ES2022",
    // Node-targeted package using Node-only APIs (Timeout.unref, process.env), so it needs real
    // Node types. @types/node is a devDependency so the isolated CI build can resolve it.
    "types": ["node"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "jsx": "react"
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
